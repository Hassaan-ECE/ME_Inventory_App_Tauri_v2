{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ME Inventory",
  "version": "0.9.8",
  "identifier": "com.me.inventory",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ME Inventory",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "publisher": "Syed Hassaan Shah",
    "copyright": "Copyright (c) 2026 Syed Hassaan Shah",
    "resources": ["../data/me_inventory.db", "../data/me_lab_inventory.db"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "installerHooks": "windows/nsis-hooks.nsh"
      }
    },
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzMDVERjg3NzMyQzdCOTcKUldTWGV5eHpoOThGSTBmelRDMG9iZzgrTW5nWXNZT01tUU1iYUxJd3FWOThyOGQ4cnA0ZmRNWEcK",
      "endpoints": [
        "https://github.com/Hassaan-ECE/ME_Inventory_App_Tauri_v2/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
